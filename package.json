{
  "name": "copilot-town",
  "version": "0.1.0",
  "description": "Copilot Town — Web dashboard for managing Copilot CLI agent ecosystem",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "cd client && npm install && npx vite build",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "cd client && npx vite --port 3847",
    "build": "cd client && npx vite build",
    "start": "tsx server/index.ts",
    "start:bg": "node scripts/ctl.cjs start --no-browser",
    "stop": "node scripts/ctl.cjs stop"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "open": "^11.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
